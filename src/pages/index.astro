---
import '../styles/global.css';

const services = [
  {
    number: '01',
    title: 'モバイル端末販売',
    lead: '売り場に立ち、来店されたお客様へ最適な提案を行います。',
    desc: '家電量販店・商業施設などで、docomo・au・SoftBankの販売業務を担当します。',
  },
  {
    number: '02',
    title: '法人営業サポート',
    lead: '企業向けの通信回線・端末導入をサポートします。',
    desc: '中小企業のお客様を中心に、利用状況に合わせた提案と営業支援を行います。',
  },
  {
    number: '03',
    title: '販売スタッフ配置',
    lead: 'イベントや店舗の状況に合わせてスタッフを配置します。',
    desc: '九州を中心に全国各地へ、短期・長期どちらの現場にも柔軟に対応します。',
  },
];

const companyRows = [
  ['会社名', '株式会社NEXTRIBE'],
  ['設立', '2016年10月14日'],
  ['所在地', '福岡県福岡市城南区荒江'],
  ['事業内容', 'モバイルキャリア販売代行'],
  ['対応キャリア', 'docomo / au / SoftBank'],
  ['活動エリア', '九州を中心に全国各地'],
];

const recruitRows = [
  ['雇用形態', '正社員 / アルバイト'],
  ['給与', '正社員：月給 280,000円〜<br />アルバイト：時給 2,000円〜'],
  ['賞与', '業績により支給'],
  ['勤務地', '九州を中心に全国各地'],
  ['勤務時間', 'シフト制'],
  ['経験', '未経験歓迎'],
];
---

<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="株式会社NEXTRIBE - 九州を中心に全国展開するモバイルキャリア販売代行・フィールドセールス企業" />
  <title>株式会社NEXTRIBE</title>
  <link rel="icon" href="/favicon.ico" />
</head>
<body>
  <div class="site-shell">
    <nav id="navbar" class="site-nav">
      <a href="/" class="brand" aria-label="NEXTRIBE トップへ">
        <img class="brand-mark" src="/logo-mark-dark.png" alt="" aria-hidden="true" />
        <span>NEXTRIBE</span>
      </a>
      <div class="nav-links">
        <a href="#about">ABOUT</a>
        <a href="#service">SERVICE</a>
        <a href="/company">COMPANY</a>
        <a href="#recruit">RECRUIT</a>
        <a href="#contact">CONTACT</a>
      </div>
      <button id="menu-btn" class="menu-button" aria-label="メニューを開く">
        <span></span><span></span>
      </button>
    </nav>

    <div id="mobile-menu" class="mobile-menu hidden">
      <button id="menu-close" class="menu-close" aria-label="メニューを閉じる">×</button>
      <a class="mobile-link" href="#about">ABOUT</a>
      <a class="mobile-link" href="#service">SERVICE</a>
      <a class="mobile-link" href="/company">COMPANY</a>
      <a class="mobile-link" href="#recruit">RECRUIT</a>
      <a class="mobile-link" href="#contact">CONTACT</a>
    </div>

    <header class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-orbit" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <div class="hero-inner">
        <div class="hero-kicker reveal">FIELD SALES / MOBILE CARRIER / JAPAN</div>
        <h1 class="hero-title reveal">
          <span>通信の現場に、</span>
          <span>人の力を。</span>
        </h1>
        <p class="hero-copy reveal">
          NEXTRIBEは、docomo・au・SoftBankの販売業務を中心に、
          店舗・イベント・法人営業の現場を支える会社です。福岡を拠点に、九州から全国各地まで対応しています。
        </p>
        <div class="hero-actions reveal">
          <a class="primary-btn" href="#recruit">採用情報を見る</a>
          <a class="ghost-btn" href="#service">事業内容を見る</a>
        </div>
      </div>
      <div class="hero-panel reveal-right">
        <div class="panel-top">
          <span>ACTIVE AREA</span>
          <strong>KYUSHU → JAPAN</strong>
        </div>
        <div class="signal-map" aria-hidden="true">
          <div class="signal-core"></div>
          <i class="route r1"></i>
          <i class="route r2"></i>
          <i class="route r3"></i>
        </div>
        <div class="panel-bottom">
          <span>docomo</span>
          <span>au</span>
          <span>SoftBank</span>
        </div>
      </div>
      <div class="scroll-note" aria-hidden="true">SCROLL</div>
    </header>

    <section class="metrics">
      <div class="metric reveal">
        <strong data-count="3">0</strong>
        <span>キャリア対応</span>
      </div>
      <div class="metric reveal">
        <strong>九州</strong>
        <span>中心に全国展開</span>
      </div>
      <div class="metric reveal">
        <strong>2016</strong>
        <span>年設立</span>
      </div>
      <div class="metric reveal">
        <strong>福岡</strong>
        <span>を拠点に展開</span>
      </div>
    </section>

    <main>
      <section id="about" class="section split-section">
        <div class="section-heading reveal-left">
          <p>01 / ABOUT</p>
          <h2>売り場に立つ人を、<br />大切にする会社です。</h2>
        </div>
        <div class="section-body reveal-right">
          <p>
            NEXTRIBEは、通信キャリアの販売現場で働くスタッフを支えながら、
            お客様にわかりやすく、納得できる提案を届けています。
          </p>
          <p>
            福岡を拠点に、九州を中心として全国各地の案件に対応しています。
            現場ごとの状況に合わせて、必要な人員と動き方を整えます。
          </p>
        </div>
      </section>

      <section id="service" class="section">
        <div class="section-heading reveal">
          <p>02 / SERVICE</p>
          <h2>事業内容</h2>
        </div>
        <div class="service-grid">
          {services.map((service, index) => (
            <article class="service-card reveal" style={`transition-delay:${index * 0.12}s`}>
              <span>{service.number}</span>
              <h3>{service.title}</h3>
              <strong>{service.lead}</strong>
              <p>{service.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="company" class="section company-band">
        <div class="section-heading reveal-left">
          <p>03 / COMPANY</p>
          <h2>会社情報</h2>
          <a class="text-link" href="/company">詳しい会社概要へ</a>
        </div>
        <div class="company-list reveal-right">
          {companyRows.map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </div>
      </section>

      <section id="recruit" class="section recruit-section">
        <div class="recruit-copy reveal-left">
          <p class="eyebrow">04 / RECRUIT</p>
          <h2>一緒に働く仲間を<br />募集しています。</h2>
          <p>
            未経験でも、接客が好きな方、人と話すことが好きな方を歓迎します。
            現場での経験を重ねながら、販売スキルや提案力を身につけられます。
          </p>
          <a class="primary-btn" href="#contact">応募・お問い合わせ</a>
        </div>
        <div class="recruit-card reveal-right">
          {recruitRows.map(([label, value]) => (
            <div>
              <span>{label}</span>
              <strong set:html={value} />
            </div>
          ))}
        </div>
      </section>

      <section id="contact" class="section contact-section">
        <div class="contact-header reveal">
          <p>05 / CONTACT</p>
          <h2>お問い合わせ</h2>
          <span>採用・事業に関するご相談はこちらから。</span>
        </div>
        <form id="contact-form" class="contact-form reveal" name="contact" method="POST" action="/thanks" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p hidden><input name="bot-field" /></p>
          <label>
            <span>お名前</span>
            <input type="text" name="お名前" required placeholder="山田 太郎" />
          </label>
          <label>
            <span>メールアドレス</span>
            <input type="email" name="メールアドレス" required placeholder="example@email.com" />
          </label>
          <label>
            <span>お問い合わせ種別</span>
            <select name="種別">
              <option value="">選択してください</option>
              <option value="採用について">採用について</option>
              <option value="事業について">事業について</option>
              <option value="その他">その他</option>
            </select>
          </label>
          <label>
            <span>メッセージ</span>
            <textarea name="メッセージ" required rows="5" placeholder="お問い合わせ内容をご記入ください"></textarea>
          </label>
          <button class="primary-btn" type="submit">送信する</button>
        </form>
        <p class="mail-link reveal">
          メール：<a href="mailto:nextribe.info@gmail.com">nextribe.info@gmail.com</a>
        </p>
      </section>
    </main>

    <footer class="site-footer">
      <a href="/" class="brand">
        <img class="brand-mark small" src="/logo-mark-dark.png" alt="" aria-hidden="true" />
        <span>NEXTRIBE</span>
      </a>
      <div class="footer-links">
        <a href="#about">ABOUT</a>
        <a href="#service">SERVICE</a>
        <a href="/company">COMPANY</a>
        <a href="#recruit">RECRUIT</a>
        <a href="#contact">CONTACT</a>
      </div>
      <p>© 2026 株式会社NEXTRIBE</p>
    </footer>
  </div>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('nav-scrolled', window.scrollY > 48);
    });

    const menuBtn = document.getElementById('menu-btn');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const openMenu = () => mobileMenu?.classList.remove('hidden');
    const closeMenu = () => mobileMenu?.classList.add('hidden');
    menuBtn?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);
    document.querySelectorAll('.mobile-link').forEach((link) => link.addEventListener('click', closeMenu));

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.14 });
    document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((el) => observer.observe(el));

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const target = Number(entry.target.getAttribute('data-count') || '0');
        let current = 0;
        const timer = setInterval(() => {
          current += target / 26;
          if (current >= target) {
            entry.target.textContent = String(target);
            clearInterval(timer);
          } else {
            entry.target.textContent = String(Math.floor(current));
          }
        }, 24);
        countObserver.unobserve(entry.target);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach((el) => countObserver.observe(el));
  </script>
</body>
</html>
