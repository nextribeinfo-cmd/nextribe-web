    icon: `<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="sg3" x1="0" y1="0" x2="64" y2="64"><stop offset="0" stop-color="#5aa6ff"/><stop offset="1" stop-color="#2b6fe0"/></linearGradient></defs><path d="M32 10c-7 0-12 5-12 12 0 8 12 22 12 22s12-14 12-22c0-7-5-12-12-12z" stroke="url(#sg3)" stroke-width="2.5" stroke-linejoin="round"/><circle cx="32" cy="22" r="4.5" stroke="url(#sg3)" stroke-width="2.5"/><path d="M14 40c-2 1-4 3-4 6 0 4 5 6 10 6" stroke="#5aa6ff" stroke-width="2.2" stroke-linecap="round" opacity="0.6"/><path d="M50 40c2 1 4 3 4 6 0 4-5 6-10 6" stroke="#5aa6ff" stroke-width="2.2" stroke-linecap="round" opacity="0.6"/><circle cx="14" cy="34" r="2.4" fill="#5aa6ff" opacity="0.7"/><circle cx="50" cy="34" r="2.4" fill="#5aa6ff" opacity="0.7"/></svg>`,
